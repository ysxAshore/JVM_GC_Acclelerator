import re
import sys

ACCESS_RE = re.compile(r'access ([0-9a-f]+) \((\d+) bytes\) to (get|write)(?: ([0-9a-f]+))?')
PAR_ASSIGN_RE = re.compile(r'par\.(\w+)\s*=\s*(0x[0-9a-fA-F]+|\d+)\s*')

def gen_store(addr, size, val):
    return f"store{size * 8}(0x{addr}, 0x{val});"

def gen_map(addr):
    return f"shadow_addr(0x{addr});"

def need_shadow(field, value):
    if not value.startswith("0x"):
        return False
    if field.startswith("compressed"):
        return False
    return True

def main(trace_path):
    sequences = []
    par_dumps = []
    seen_addrs = set()

    with open(trace_path) as f:
        for line in f:
            # ---- access ----
            m = ACCESS_RE.search(line)
            if m:
                addr, size, op, val = m.groups()
                size = int(size)

                if op == "get":
                    if addr not in seen_addrs:
                        # store origin value
                        sequences.append(gen_store(addr, size, val))
                        seen_addrs.add(addr)
                continue

            # ---- par dump ----
            m = PAR_ASSIGN_RE.search(line)
            if m:
                field, value = m.groups()
                par_dumps.append(f"par.{field} = {value};")

    # 输出 test C
    print("/* === test.c === */")
    print("#include \"test.h\"")
    print("int main(void) {")
    print("\n", "   struct HWGCParameters par;")
    print("\n", "/* === par dump (raw, to be structured) === */")
    for p in par_dumps:
        print("   ", p);

    print("\n/* === memory restore  === */")
    for s in sequences:
        print("   ", s);
 
    print()
    print("   ", "int fd = open(\"/dev/hwgc\", O_RDWR);")
    print("   ", "int state;")
    print("   ", "ioctl(fd, HWGC_IOC_START, &par);")

    print()
    print("   ", "while(1) {")
    print("      ", "ioctl(fd, HWGC_IOC_WAIT_EVENT, &state);")
    print("      ", "if (state == HWGC_WAIT_PAGEFAULT) {")
    print("         ", "lseek(fd, 0xe0, SEEK_SET);")
    print("         ", "uintptr_t vaddr, data, write, size;")
    print("         ", "read(fd, &vaddr, sizeof(vaddr));")
    print("         ", "read(fd, &data, sizeof(data));")
    print("         ", "read(fd, &write, sizeof(write));")
    print("         ", "read(fd, &size, sizeof(size));")
    print()
    print("         ", "uint64_t return_value = 0;")
    print("         ", "if (write)")
    print("            ", "memcpy(shadow_addr(vaddr), &data, size);")
    print("         ", "else")
    print("            ", "memcpy(&return_value, shadow_addr(vaddr), size);")
    print("         ", "ioctl(fd, HWGC_IOC_SOFT_PROVIDE, &return_value);")
    print("      ", "}")
    print("      ", "if (state == HWGC_DONE) {")
    print("         ", "printf(\"work down\\n\");")
    print("         ", "break;")
    print("      ", "}")
    print("   ", "}")

    print("   ", "return 0;");
    print("}");

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("usage: python trace2c.py trace.log")
        sys.exit(1)

    main(sys.argv[1])

